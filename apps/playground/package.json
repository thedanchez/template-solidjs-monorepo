    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@scope/hello-a": "workspace:*",
    "@scope/hello-b": "workspace:*",
    "@solidjs/router": "catalog:solid"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.2",
    "solid-js": "catalog:solid",
    "vite": "catalog:tooling",
    "vite-plugin-solid": "catalog:solid"
  }
}
